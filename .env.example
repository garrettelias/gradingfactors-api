# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Supabase project URL (found in: Project Settings > API > Project URL)
SUPABASE_URL=https://xxxx.supabase.co

# Supabase service role key — grants full DB access, server-side only, never expose publicly
# (found in: Project Settings > API > service_role key)
SUPABASE_SERVICE_KEY=xxxx

# Base URL for CGC grading guide pages — used by the scraper
CGC_BASE_URL=https://www.grainscanada.gc.ca/en/grain-quality/official-grain-grading-guide

# development or production
ENVIRONMENT=development
